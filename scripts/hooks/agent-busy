#!/usr/bin/env bash
STATUS_DIR="${ATMUX_WORKSPACE:-.}/.atmux/status"
AGENT_NAME="${ATMUX_AGENT:-unknown}"

[[ -n "$ATMUX_DEBUG" ]] && echo "[$(date '+%H:%M:%S')] agent-busy     agent=$AGENT_NAME" >> "$STATUS_DIR/hooks.log"

echo "busy" > "$STATUS_DIR/$AGENT_NAME"

tmux set-window-option -t "$ATMUX_SESSION:$AGENT_NAME" window-status-style "fg=colour214" 2>/dev/null || true
tmux set-window-option -t "$ATMUX_SESSION:$AGENT_NAME" window-status-current-style "fg=colour235,bg=colour214,bold" 2>/dev/null || true
