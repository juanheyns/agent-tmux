#!/usr/bin/env bash
set -euo pipefail

# Resolve through symlinks to find the real install directory
ATMUX_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$ATMUX_SOURCE" ]]; do
  ATMUX_DIR="$(cd "$(dirname "$ATMUX_SOURCE")" && pwd)"
  ATMUX_SOURCE="$(readlink "$ATMUX_SOURCE")"
  [[ "$ATMUX_SOURCE" != /* ]] && ATMUX_SOURCE="$ATMUX_DIR/$ATMUX_SOURCE"
done
ATMUX_DIR="$(cd "$(dirname "$ATMUX_SOURCE")" && pwd)"
TMUX_CONF="$ATMUX_DIR/.tmux.conf"

usage() {
  cat <<EOF
Usage: atmux <command>

Commands:
  init                              Initialize a new workspace
  start                             Launch the atmux session (or just: atmux)
  stop                              Stop all agents and the session
  add <name> <repo> [--harness X] [-- flags]  Add a new agent (default: claude)
  remove <name>                     Remove an agent
  send <name> <msg>                 Send a message to an agent
  list                              List configured agents
  heartbeat <name|all> <secs> <msg> Set a heartbeat for idle agents
  heartbeat stop <name|all>         Stop a heartbeat
  heartbeat list                    List active heartbeats
  shell <dir>                       Open a new shell window at <dir>
  help                              Show this help

Run 'atmux init' first, then 'atmux start' to launch.
EOF
  exit 0
}

# Find the workspace (.atmux/ in cwd or parents)
find_workspace() {
  local d
  d="$(pwd)"
  while true; do
    if [[ -d "$d/.atmux" ]]; then
      echo "$d"
      return 0
    fi
    local parent
    parent="$(dirname "$d")"
    if [[ "$parent" == "$d" ]]; then
      return 1
    fi
    d="$parent"
  done
}

require_workspace() {
  WORKSPACE="$(find_workspace)" || {
    echo "Error: Not in an atmux workspace. Run 'atmux init' first."
    exit 1
  }
  # Auto-migrate older workspaces
  python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import migrate_workspace
from pathlib import Path
migrate_workspace(Path('$WORKSPACE'))
" 2>/dev/null || true
  SESSION=$(python3 -c "import json; print(json.load(open('$WORKSPACE/.atmux/config.json')).get('session', 'atmux'))" 2>/dev/null || echo "atmux")
}

# --- Commands ---

cmd_init() {
  if [[ -d ".atmux" ]]; then
    echo "Workspace already initialized in $(pwd)"
    exit 0
  fi

  python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import init_workspace
from pathlib import Path
init_workspace(Path('.').resolve())
"
  echo "Initialized atmux workspace in $(pwd)"
  echo "  .atmux/config.json   — workspace settings"
  echo "  .atmux/agents.json   — agent registry"
  echo ""
  echo "Next: atmux add <name> <repo>   then   atmux start"
}

cmd_start() {
  require_workspace

  # Preflight
  if ! command -v tmux &>/dev/null; then
    echo "Error: tmux is not installed. Run: brew install tmux"
    exit 1
  fi
  # Check that all required harness binaries are available
  agents_json="$WORKSPACE/.atmux/agents.json"
  if [[ -f "$agents_json" ]]; then
    required_binaries=$(python3 -c "
import json, sys; sys.path.insert(0, '$ATMUX_DIR')
from src.harness import get_harness, DEFAULT_HARNESS
agents = json.load(open('$agents_json'))
seen = set()
for a in agents:
    h = a.get('harness', DEFAULT_HARNESS)
    seen.add(get_harness(h)['binary'])
if not seen:
    seen.add(get_harness(DEFAULT_HARNESS)['binary'])
for b in sorted(seen):
    print(b)
" 2>/dev/null || echo "claude")
    for bin in $required_binaries; do
      if ! command -v "$bin" &>/dev/null; then
        echo "Error: $bin is not installed (required by at least one agent)."
        exit 1
      fi
    done
  else
    if ! command -v claude &>/dev/null; then
      echo "Error: claude is not installed."
      exit 1
    fi
  fi

  # Handle existing session
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    read -rp "Session '$SESSION' already exists. Kill it? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      tmux kill-session -t "$SESSION"
    else
      echo "Attaching to existing session..."
      exec tmux attach -t "$SESSION"
    fi
  fi

  echo "Launching atmux..."
  echo "Workspace: $WORKSPACE"

  # Ensure status dir
  mkdir -p "$WORKSPACE/.atmux/status"

  # Window 0: overview dashboard
  tmux -f "$TMUX_CONF" new-session -d -s "$SESSION" -n "overview" -c "$WORKSPACE"
  tmux send-keys -t "$SESSION:overview" \
    "export ATMUX_DIR='$ATMUX_DIR' ATMUX_SESSION='$SESSION' ATMUX_WORKSPACE='$WORKSPACE'; cd '$ATMUX_DIR' && python3 -m src dashboard '$WORKSPACE'" Enter

  # Launch persisted agents
  agents_json="$WORKSPACE/.atmux/agents.json"
  if [[ -f "$agents_json" ]]; then
    agent_count=$(python3 -c "import json; print(len(json.load(open('$agents_json'))))" 2>/dev/null || echo "0")

    if [[ "$agent_count" -gt 0 ]]; then
      echo "Restoring $agent_count agent(s)..."
      python3 -c "
import json
for a in json.load(open('$agents_json')):
    print(a['name'] + '\t' + a['dir'] + '\t' + a.get('harness', 'claude') + '\t' + a.get('flags', ''))
" | while IFS=$'\t' read -r name agent_dir agent_harness agent_flags; do
        # Default harness for pre-migration workspaces
        [[ -z "$agent_harness" ]] && agent_harness="claude"

        if [[ ! -d "$agent_dir" ]]; then
          echo "  Skipping $name — directory not found: $agent_dir"
          continue
        fi

        echo "  Starting $name ($agent_harness) -> $agent_dir"

        tmux new-window -t "$SESSION" -n "$name" -c "$agent_dir"

        # Initialize status
        echo "idle" > "$WORKSPACE/.atmux/status/$name"
        echo "0" > "$WORKSPACE/.atmux/status/${name}.subagents"

        # Build launch command via harness module
        launch_cmd=$(python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.harness import build_launch_cmd, ensure_settings
ensure_settings('$agent_harness', '$agent_dir', '$ATMUX_DIR')
print(build_launch_cmd('$agent_harness', '$name', '$ATMUX_DIR', '$SESSION', '$WORKSPACE', '${agent_flags}'))
")
        tmux send-keys -t "$SESSION:$name" "$launch_cmd" Enter
      done

      # Wait for agent sessions to initialize
      sleep 3
    fi
  fi

  # Focus overview
  tmux select-window -t "$SESSION:overview"

  echo "Attaching..."
  exec tmux attach -t "$SESSION"
}

cmd_stop() {
  require_workspace

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No atmux session running."
    exit 0
  fi

  echo "Stopping atmux..."

  # Build window->exit_command map from agents.json
  local exit_cmds
  exit_cmds=$(python3 -c "
import sys, json; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import load_agents
from src.harness import get_exit_command
from pathlib import Path
for a in load_agents(Path('$WORKSPACE')):
    print(a['name'] + '\t' + get_exit_command(a.get('harness', 'claude')))
" 2>/dev/null || true)

  # Send exit command to all agent windows
  tmux list-windows -t "$SESSION" -F "#W" 2>/dev/null | while read -r window; do
    if [[ "$window" != "overview" ]]; then
      echo "  Stopping $window..."
      local exit_cmd="/exit"
      if [[ -n "$exit_cmds" ]]; then
        local matched
        matched=$(echo "$exit_cmds" | grep "^${window}	" | cut -f2)
        [[ -n "$matched" ]] && exit_cmd="$matched"
      fi
      tmux send-keys -t "$SESSION:$window" "$exit_cmd" Enter 2>/dev/null || true
    fi
  done

  # Stop overview
  tmux send-keys -t "$SESSION:overview" "q" 2>/dev/null || true

  sleep 3

  # Clean up runtime status
  rm -f "$WORKSPACE/.atmux/status/"* 2>/dev/null || true

  tmux kill-session -t "$SESSION" 2>/dev/null || true
  echo "atmux stopped. Agents preserved in .atmux/agents.json."
}

cmd_add() {
  require_workspace

  local name="${1:-}"
  local repo="${2:-}"
  shift 2 2>/dev/null || true

  # Parse --harness and collect extra flags after --
  local agent_harness="claude"
  local agent_flags=""
  local found_dashdash=false
  while [[ $# -gt 0 ]]; do
    if [[ "$found_dashdash" == true ]]; then
      agent_flags="$agent_flags $1"
    elif [[ "$1" == "--" ]]; then
      found_dashdash=true
    elif [[ "$1" == "--harness" ]]; then
      shift
      agent_harness="${1:-claude}"
    fi
    shift
  done

  if [[ -z "$name" || -z "$repo" ]]; then
    echo "Usage: atmux add <name> <repo-or-path> [--harness claude|codex] [-- extra-flags]"
    echo ""
    echo "  <repo-or-path> can be:"
    echo "    owner/repo                      GitHub shorthand"
    echo "    https://github.com/owner/repo   Full URL (any git host)"
    echo "    git@host:owner/repo.git         SSH URL"
    echo "    /absolute/path                  Existing local directory"
    echo "    ./relative/path                 Existing local directory"
    echo ""
    echo "  Extra flags are passed to the harness on launch, e.g.:"
    echo "    atmux add dev1 owner/repo -- --model sonnet"
    echo "    atmux add dev2 /path --harness codex"
    exit 1
  fi

  # Determine working directory
  local agent_dir
  if [[ "$repo" == /* || "$repo" == ./* || "$repo" == ~* ]]; then
    local expanded="${repo/#\~/$HOME}"
    if [[ "$expanded" != /* ]]; then
      expanded="$WORKSPACE/$expanded"
    fi
    mkdir -p "$expanded"
    agent_dir="$(cd "$expanded" && pwd)"
  else
    agent_dir="$WORKSPACE/agents/$name"
    if [[ ! -d "$agent_dir/.git" ]]; then
      echo "Cloning $repo into agents/$name/..."
      mkdir -p "$agent_dir"
      # Use git clone for URLs, gh repo clone for owner/repo shorthand
      if [[ "$repo" == https://* || "$repo" == http://* || "$repo" == git@* || "$repo" == ssh://* ]]; then
        git clone --quiet "$repo" "$agent_dir"
      else
        gh repo clone "$repo" "$agent_dir" -- --quiet
      fi
    else
      echo "Already cloned."
    fi
  fi

  # Persist to agents.json (with optional flags and harness)
  python3 -c "
import sys, json; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import add_agent
from pathlib import Path
add_agent(Path('$WORKSPACE'), '$name', '$repo', '$agent_dir', flags='${agent_flags# }', harness='$agent_harness')
"
  echo "Added agent '$name' -> $repo"
  echo "  dir: $agent_dir"
  echo "  harness: $agent_harness"
  [[ -n "$agent_flags" ]] && echo "  flags:$agent_flags"

  # If session is running, also launch it live
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux new-window -t "$SESSION" -n "$name" -c "$agent_dir"

    mkdir -p "$WORKSPACE/.atmux/status"
    echo "idle" > "$WORKSPACE/.atmux/status/$name"
    echo "0" > "$WORKSPACE/.atmux/status/${name}.subagents"

    launch_cmd=$(python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.harness import build_launch_cmd, ensure_settings
ensure_settings('$agent_harness', '$agent_dir', '$ATMUX_DIR')
print(build_launch_cmd('$agent_harness', '$name', '$ATMUX_DIR', '$SESSION', '$WORKSPACE', '${agent_flags# }'))
")
    tmux send-keys -t "$SESSION:$name" "$launch_cmd" Enter
    echo "Agent launched in session."
  fi
}

_remove_one_agent() {
  local name="$1"

  # Look up exit command before removing from agents.json
  local exit_cmd
  exit_cmd=$(python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import get_agent
from src.harness import get_exit_command
from pathlib import Path
a = get_agent(Path('$WORKSPACE'), '$name')
print(get_exit_command((a or {}).get('harness', 'claude')))
" 2>/dev/null || echo "/exit")

  python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import remove_agent
from pathlib import Path
remove_agent(Path('$WORKSPACE'), '$name')
"

  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux send-keys -t "$SESSION:$name" "$exit_cmd" Enter 2>/dev/null || true
    sleep 1
    tmux kill-window -t "$SESSION:$name" 2>/dev/null || true
  fi

  rm -f "$WORKSPACE/.atmux/status/$name" "$WORKSPACE/.atmux/status/${name}.subagents" "$WORKSPACE/.atmux/status/${name}.repo" 2>/dev/null || true

  echo "Removed agent '$name'"
}

cmd_remove() {
  require_workspace

  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: atmux remove <name|all>"
    exit 1
  fi

  if [[ "$name" == "all" ]]; then
    local agents
    agents=$(python3 -c "
import sys, json; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import load_agents
from pathlib import Path
for a in load_agents(Path('$WORKSPACE')):
    print(a['name'])
")
    if [[ -z "$agents" ]]; then
      echo "No agents configured."
      exit 0
    fi
    while read -r agent; do
      _remove_one_agent "$agent"
    done <<< "$agents"
  else
    _remove_one_agent "$name"
  fi
}

cmd_send() {
  require_workspace

  local name="${1:-}"
  shift || true
  local msg="$*"

  if [[ -z "$name" || -z "$msg" ]]; then
    echo "Usage: atmux send <name|all> <message>"
    exit 1
  fi

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Error: No atmux session running. Run: atmux start"
    exit 1
  fi

  if [[ "$name" == "all" ]]; then
    local agents
    agents=$(python3 -c "
import sys, json; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import load_agents
from pathlib import Path
for a in load_agents(Path('$WORKSPACE')):
    print(a['name'])
")
    if [[ -z "$agents" ]]; then
      echo "No agents configured."
      exit 1
    fi
    while read -r agent; do
      tmux send-keys -t "$SESSION:$agent" "$msg" Enter 2>/dev/null && \
        echo "Sent to $agent: $msg" || \
        echo "Warning: could not send to $agent"
    done <<< "$agents"
  else
    tmux send-keys -t "$SESSION:$name" "$msg" Enter
    echo "Sent to $name: $msg"
  fi
}

cmd_list() {
  require_workspace

  echo "Workspace: $WORKSPACE"
  echo ""

  python3 -c "
import sys, json; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import load_agents
from pathlib import Path
agents = load_agents(Path('$WORKSPACE'))
if not agents:
    print('  No agents configured. Use: atmux add <name> <repo>')
else:
    for a in agents:
        h = a.get('harness', 'claude')
        print(f\"  {a['name']:<16} [{h:<6}] {a['repo']:<30} {a['dir']}\")
"
}

cmd_heartbeat() {
  require_workspace

  local subcmd="${1:-}"

  if [[ "$subcmd" == "list" ]]; then
    python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import load_heartbeats
from pathlib import Path
hbs = load_heartbeats(Path('$WORKSPACE'))
if not hbs:
    print('  No heartbeats configured.')
else:
    for h in hbs:
        print(f\"  {h['agent']:<14} every {h['interval']}s: {h['message']}\")
"
    return
  fi

  if [[ "$subcmd" == "stop" ]]; then
    local target="${2:-all}"
    python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import remove_heartbeat
from pathlib import Path
remove_heartbeat(Path('$WORKSPACE'), '$target')
"
    echo "Heartbeat stopped for $target"
    return
  fi

  local agent="${1:-}"
  local interval="${2:-}"
  local msg="${3:-}"

  if [[ -z "$agent" || -z "$interval" || -z "$msg" ]]; then
    echo "Usage: atmux heartbeat <agent|all> <seconds> <message>"
    echo "       atmux heartbeat stop <agent|all>"
    echo "       atmux heartbeat list"
    exit 1
  fi

  python3 -c "
import sys; sys.path.insert(0, '$ATMUX_DIR')
from src.workspace import set_heartbeat
from pathlib import Path
set_heartbeat(Path('$WORKSPACE'), '$agent', $interval, '$msg')
"
  echo "Heartbeat set: $agent every ${interval}s"
}

cmd_shell() {
  require_workspace

  local dir="${1:-}"

  if [[ -z "$dir" ]]; then
    echo "Usage: atmux shell <directory>"
    exit 1
  fi

  # Resolve the directory
  local resolved
  local expanded="${dir/#\~/$HOME}"
  if [[ "$expanded" != /* ]]; then
    expanded="$WORKSPACE/$expanded"
  fi
  mkdir -p "$expanded"
  resolved="$(cd "$expanded" && pwd)"

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Error: No atmux session running. Run: atmux start"
    exit 1
  fi

  # Use the directory basename as the window name
  local win_name
  win_name="$(basename "$resolved")"

  tmux new-window -t "$SESSION" -n "$win_name" -c "$resolved"
  echo "Opened shell '$win_name' at $resolved"
}

# --- Dispatch ---

cmd="${1:-start}"
shift 2>/dev/null || true

case "$cmd" in
  init)       cmd_init ;;
  start)      cmd_start ;;
  stop)       cmd_stop ;;
  add)        cmd_add "$@" ;;
  remove)     cmd_remove "$@" ;;
  send)       cmd_send "$@" ;;
  list|ls)    cmd_list ;;
  heartbeat)  cmd_heartbeat "$@" ;;
  shell)      cmd_shell "$@" ;;
  -h|--help|help) usage ;;
  *)
    echo "Unknown command: $cmd"
    usage
    ;;
esac
